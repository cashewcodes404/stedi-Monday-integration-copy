# ─── Monday.com API ───────────────────────────────────────────
# Get from: Monday.com → Admin → API
MONDAY_API_TOKEN=

# Board IDs — find in the URL when viewing each board
# e.g., https://your-account.monday.com/boards/1234567890
MONDAY_ORDER_BOARD_ID=
MONDAY_CLAIMS_BOARD_ID=

# ─── Stedi API ────────────────────────────────────────────────
# Get from: https://www.stedi.com/app/settings/api-keys
STEDI_API_KEY=

# ─── Webhook Security ────────────────────────────────────────
# Monday webhook signing secret (optional)
WEBHOOK_SECRET=

# ─── Server ───────────────────────────────────────────────────
PORT=5000

# ─── Notes ────────────────────────────────────────────────────
# If MONDAY_API_TOKEN is not set, the app runs in mock mode:
#   - Monday read/write operations return mock data
#   - Useful for testing claim building logic without API access
#
# If STEDI_API_KEY is not set, the app runs in mock mode:
#   - Claim submissions return mock responses
#   - 277/835 fetches return sample data
#   - Useful for testing the full flow end-to-end locally
